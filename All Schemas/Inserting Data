/* =========================================
   DATA LOADING SCRIPT (BULK INSERT)
   ========================================= */

USE SQL_Project;
GO

/*
IMPORTANT:
- Place all CSV files inside a folder like: /data/
- Update file paths before running (SQL Server needs local access)
*/

-- ========================
-- 1. CUSTOMERS
-- ========================
BULK INSERT Customers
FROM 'C:\SQL_Project\data\customers.csv'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '\n',
    TABLOCK
);

-- ========================
-- 2. CATEGORIES
-- ========================
BULK INSERT Categories
FROM 'C:\SQL_Project\data\categories.csv'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '\n',
    TABLOCK
);

-- ========================
-- 3. PRODUCTS
-- ========================
BULK INSERT Products
FROM 'C:\SQL_Project\data\products.csv'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '\n',
    TABLOCK
);

-- ========================
-- 4. SUPPLIERS
-- ========================
BULK INSERT Suppliers
FROM 'C:\SQL_Project\data\suppliers.csv'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '\n',
    TABLOCK
