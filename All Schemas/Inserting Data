-- ========================
-- 5. ORDERS
-- ========================
BULK INSERT Orders
FROM 'C:\SQL_Project\data\orders.csv'
WITH (
    FIRSTROW = 2,
    FIELDTERMINATOR = ',',
    ROWTERMINATOR = '0x0a',
